# Copy to .env and fill in. All values are optional except the shared LLM
# fallback if you want tier-3 answers without per-user keys or Ollama.

# --- Shared fallback LLM ("Kimi" tier 3) -------------------------------------
CODEATLAS_LLM_PROVIDER=openai_compatible      # openai_compatible | anthropic_compatible
CODEATLAS_LLM_BASE_URL=
CODEATLAS_LLM_API_KEY=
CODEATLAS_LLM_MODEL=kimi-2.5

# --- Local Ollama (tier 2, free/private) -------------------------------------
CODEATLAS_OLLAMA_URL=http://localhost:11434
CODEATLAS_OLLAMA_MODEL=qwen2.5-coder:7b

# --- Agentic retrieval -------------------------------------------------------
# Tool-capable models search/read iteratively. Unsupported models automatically
# fall back to the original one-shot RAG path.
CODEATLAS_AGENT_ENABLED=true
CODEATLAS_AGENT_MAX_ROUNDS=8
CODEATLAS_AGENT_MAX_TOOL_CALLS=24
# CODEATLAS_AGENT_READ_LINES=240
# CODEATLAS_AGENT_READ_CHARS=30000
# CODEATLAS_AGENT_READ_FILE_BYTES=2000000
# CODEATLAS_AGENT_SEARCH_FILES=3000
# CODEATLAS_AGENT_SEARCH_FILE_BYTES=300000
# CODEATLAS_AGENT_TOOL_RESULT_CHARS=45000

# --- Paths / workspaces ------------------------------------------------------
# CODEATLAS_DATA_DIR=./data
# CODEATLAS_DEFAULT_WORKSPACE=default
# Point the default workspace's graph at an existing graph.json:
# CODEATLAS_GRAPH_PATH=/abs/path/to/graph.json
# Root of the indexed source tree (for code excerpts) when not using a clone:
# CODEATLAS_SOURCE_ROOT=/abs/path/to/source/repo
